@model BookManagment.Models.Author

@{
    ViewData["Title"] = "Add Author";
}

<div class="page-header">
    <h1>
        <span class="page-icon"><i class="bi bi-person-plus"></i></span>
        Add New Author
    </h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left mr-1"></i> Back to Authors
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">
        <div class="card tmb-card">
            <div class="card-header">
                <i class="bi bi-person-plus mr-2"></i>Author Details
            </div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" style="font-size:.85rem;"></div>

                    <div class="form-group">
                        <label asp-for="FirstName"><i class="bi bi-person mr-1"></i>First Name</label>
                        <input asp-for="FirstName" class="form-control" placeholder="Enter first name" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="LastName"><i class="bi bi-person mr-1"></i>Last Name</label>
                        <input asp-for="LastName" class="form-control" placeholder="Enter last name" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x mr-1"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check2 mr-1"></i> Create Author
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

