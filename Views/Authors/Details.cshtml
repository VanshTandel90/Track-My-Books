@model BookManagment.Models.ViewModels.AuthorIndexData

@{
    ViewData["Title"] = "Author Details";
}

<div class="page-header">
    <h1>
        <span class="page-icon"><i class="bi bi-person-lines-fill"></i></span>
        Author Details
    </h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left mr-1"></i> Back to Authors
    </a>
</div>

@foreach (var author in Model.Authors)
{
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card tmb-card">
                <div class="card-header">
                    <span class="avatar-initials" style="width:28px;height:28px;font-size:.65rem;margin-right:.5rem;">
                        @(author.FirstName.Length > 0 ? author.FirstName[0].ToString() : "")@(author.LastName.Length > 0 ? author.LastName[0].ToString() : "")
                    </span>
                    @author.FullName
                </div>
                <div class="card-body">
                    <dl class="row tmb-detail-list">
                        <dt class="col-sm-4">First Name</dt>
                        <dd class="col-sm-8">@author.FirstName</dd>

                        <dt class="col-sm-4">Last Name</dt>
                        <dd class="col-sm-8">@author.LastName</dd>

                        <dt class="col-sm-4">Books</dt>
                        <dd class="col-sm-8">
                            @if (Model.Books != null)
                            {
                                @foreach (var book in Model.Books)
                                {
                                    <span class="badge badge-author mr-1">@book.Title</span>
                                }
                            }
                        </dd>
                    </dl>

                    <div class="d-flex justify-content-between mt-3">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left mr-1"></i> Back
                        </a>
                        <a asp-action="Edit" asp-route-id="@author.Id" class="btn btn-primary">
                            <i class="bi bi-pencil mr-1"></i> Edit
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

