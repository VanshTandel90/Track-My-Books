@model BookManagment.Models.ViewModels.AuthorIndexData

@{
    ViewData["Title"] = "Authors";
}

<div class="page-header">
    <h1>
        <span class="page-icon"><i class="bi bi-people"></i></span>
        Authors
    </h1>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-person-plus mr-1"></i> Add New Author
    </a>
</div>

<div class="tmb-table">
    <table class="table mb-0">
        <thead>
            <tr>
                <th>Author</th>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Books</th>
                <th style="width:140px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Authors)
            {
                <tr>
                    <td>
                        <span class="avatar-initials">
                            @(item.FirstName.Length > 0 ? item.FirstName[0].ToString() : "")@(item.LastName.Length > 0 ? item.LastName[0].ToString() : "")
                        </span>
                    </td>
                    <td class="fw-600">@Html.DisplayFor(modelItem => item.FirstName)</td>
                    <td>@Html.DisplayFor(modelItem => item.LastName)</td>
                    <td>
                        @foreach (var ba in item.BookAuthors)
                        {
                            <span class="badge badge-author">@ba.Book.Title</span>
                        }
                    </td>
                    <td class="action-btns">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

