@model BookManagment.Models.Publisher

@{
    ViewData["Title"] = "Add Publisher";
}

<div class="page-header">
    <h1>
        <span class="page-icon"><i class="bi bi-plus-circle"></i></span>
        Add Publisher
    </h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left mr-1"></i> Back to Publishers
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-5 col-md-7">
        <div class="card tmb-card">
            <div class="card-header">
                <i class="bi bi-building mr-2"></i>Publisher Details
            </div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" style="font-size:.85rem;"></div>

                    <div class="form-group">
                        <label asp-for="PublisherName"><i class="bi bi-building mr-1"></i>Publisher Name</label>
                        <input asp-for="PublisherName" class="form-control" placeholder="Enter publisher name" />
                        <span asp-validation-for="PublisherName" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x mr-1"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check2 mr-1"></i> Create Publisher
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

