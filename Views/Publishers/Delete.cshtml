@model BookManagment.Models.Publisher

@{
    ViewData["Title"] = "Delete Publisher";
}

<div class="page-header">
    <h1>
        <span class="page-icon" style="background:linear-gradient(135deg,#e74c3c,#c0392b);">
            <i class="bi bi-trash"></i>
        </span>
        Delete Publisher
    </h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left mr-1"></i> Back to Publishers
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-5 col-md-7">
        <div class="card tmb-card">
            <div class="card-header danger">
                <i class="bi bi-exclamation-triangle mr-2"></i>Confirm Deletion
            </div>
            <div class="card-body text-center">
                <div class="delete-warning-icon">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
                <h5 class="mb-1">Delete this publisher?</h5>
                <p class="text-muted mb-4" style="font-size:.9rem;">This action cannot be undone.</p>

                <dl class="row text-left tmb-detail-list mb-4">
                    <dt class="col-sm-4">Publisher Name</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.PublisherName)</dd>
                </dl>

                <form asp-action="Delete" class="d-flex justify-content-center" style="gap: 1rem;">
                    <input type="hidden" asp-for="Id" />
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-x mr-1"></i> Cancel
                    </a>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash mr-1"></i> Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

