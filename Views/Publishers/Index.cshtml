@model IEnumerable<BookManagment.Models.Publisher>

@{
    ViewData["Title"] = "Publishers";
}

<div class="page-header">
    <h1>
        <span class="page-icon"><i class="bi bi-building"></i></span>
        Publishers
    </h1>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle mr-1"></i> Add Publisher
    </a>
</div>

<div class="tmb-table">
    <table class="table mb-0">
        <thead>
            <tr>
                <th>Publisher Name</th>
                <th style="width:140px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-600">
                        <i class="bi bi-building-fill mr-2 tmb-muted"></i>
                        @Html.DisplayFor(modelItem => item.PublisherName)
                    </td>
                    <td class="action-btns">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

