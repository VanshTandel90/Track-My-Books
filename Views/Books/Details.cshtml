@model BookManagment.Models.ViewModels.AuthorIndexData

@{
    ViewData["Title"] = "Book Details";
}

<div class="page-header">
    <h1>
        <span class="page-icon"><i class="bi bi-eye"></i></span>
        Book Details
    </h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left mr-1"></i> Back to Books
    </a>
</div>

@foreach (var book in Model.Books)
{
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9">
            <div class="card tmb-card">
                <div class="card-header">
                    <i class="bi bi-journal-text mr-2"></i>@book.Title
                </div>
                <div class="card-body">
                    <dl class="row tmb-detail-list">
                        <dt class="col-sm-4">Title</dt>
                        <dd class="col-sm-8">@book.Title</dd>

                        <dt class="col-sm-4">Publishing Date</dt>
                        <dd class="col-sm-8">@book.PublishingDate.ToShortDateString()</dd>

                        <dt class="col-sm-4">Publisher</dt>
                        <dd class="col-sm-8">@book.Publisher.PublisherName</dd>

                        <dt class="col-sm-4">Category</dt>
                        <dd class="col-sm-8">
                            @{
                                var catClass = "badge-cat-" + book.Category.ToString().ToLower();
                            }
                            <span class="badge @catClass">@book.Category</span>
                        </dd>

                        <dt class="col-sm-4">Authors</dt>
                        <dd class="col-sm-8">
                            @foreach (var author in Model.Authors)
                            {
                                <span class="badge badge-author mr-1">@author.FullName</span>
                            }
                        </dd>
                    </dl>

                    <div class="d-flex justify-content-between mt-3">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left mr-1"></i> Back
                        </a>
                        <a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-primary">
                            <i class="bi bi-pencil mr-1"></i> Edit
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

