@model BookManagment.Models.Book

@{
    ViewData["Title"] = "Add Book";
}

<div class="page-header">
    <h1>
        <span class="page-icon"><i class="bi bi-plus-circle"></i></span>
        Add New Book
    </h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left mr-1"></i> Back to Books
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7 col-md-9">
        <div class="card tmb-card">
            <div class="card-header">
                <i class="bi bi-journal-plus mr-2"></i>Book Details
            </div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" style="font-size:.85rem;"></div>

                    <div class="form-group">
                        <label asp-for="Title"><i class="bi bi-type mr-1"></i>Title</label>
                        <input asp-for="Title" class="form-control" placeholder="Enter book title" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="PublishingDate"><i class="bi bi-calendar3 mr-1"></i>Publishing Date</label>
                        <input asp-for="PublishingDate" class="form-control" type="date" />
                        <span asp-validation-for="PublishingDate" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Category"><i class="bi bi-tag mr-1"></i>Category</label>
                        <select asp-for="Category" asp-items="@Html.GetEnumSelectList<Category>()" class="form-control">
                            <option value="">-- Select a category --</option>
                        </select>
                        <span asp-validation-for="Category" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="PublisherId"><i class="bi bi-building mr-1"></i>Publisher</label>
                        <select asp-for="PublisherId" class="form-control" asp-items="ViewBag.PublisherId">
                            <option value="">-- Select a publisher --</option>
                        </select>
                        <span asp-validation-for="PublisherId" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label><i class="bi bi-people mr-1"></i>Select Authors</label>
                        <div class="checkbox-scroll-area">
                            @foreach (var author in ViewBag.Authors)
                            {
                                <div class="form-check">
                                    <input type="checkbox"
                                           class="form-check-input"
                                           id="author_@author.Id"
                                           name="selectedAuthors"
                                           value="@author.Id" />
                                    <label class="form-check-label" for="author_@author.Id">@author.FullName</label>
                                </div>
                            }
                        </div>
                        <span class="text-danger">@Html.ValidationMessage("selectedAuthors")</span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x mr-1"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check2 mr-1"></i> Create Book
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

