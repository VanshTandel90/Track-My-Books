@{
    ViewData["Title"] = "Home";
}

<div class="tmb-hero">
    <div class="position-relative" style="z-index:1;">
        <h1><i class="bi bi-book-half mr-2"></i>Track My Books</h1>
        <p>Manage your books, authors, and publishers all in one place.</p>
        @* <a asp-controller="Books" asp-action="Index" class="btn btn-light btn-sm mt-3 mr-2">
            <i class="bi bi-journals mr-1"></i> Browse Library
        </a> *@
        <a asp-controller="Books" asp-action="Create" class="btn btn-success btn-sm mt-3">
            <i class="bi bi-plus-circle mr-1"></i> Add a Book
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <a asp-controller="Books" asp-action="Index" class="stat-card">
            <div class="stat-icon books mx-auto"><i class="bi bi-journals"></i></div>
            <h5>Books</h5>
            <div class="stat-label">Browse &amp; Manage</div>
        </a>
    </div>
    <div class="col-md-4 mb-4">
        <a asp-controller="Authors" asp-action="Index" class="stat-card">
            <div class="stat-icon authors mx-auto"><i class="bi bi-people"></i></div>
            <h5>Authors</h5>
            <div class="stat-label">Browse &amp; Manage</div>
        </a>
    </div>
    <div class="col-md-4 mb-4">
        <a asp-controller="Publishers" asp-action="Index" class="stat-card">
            <div class="stat-icon pubs mx-auto"><i class="bi bi-building"></i></div>
            <h5>Publishers</h5>
            <div class="stat-label">Browse &amp; Manage</div>
        </a>
    </div>
</div>

